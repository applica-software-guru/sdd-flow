# Backend runtime configuration (non-secret template)
MONGODB_URL=mongodb://localhost:27017/sddflow
JWT_SECRET=change-me-in-production
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Compatibility mapping: if FRONTEND_URL is empty and APP_DOMAIN is set,
# the app can derive FRONTEND_URL from APP_DOMAIN.
APP_DOMAIN=
FRONTEND_URL=http://localhost:3002

# OAuth
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Cookie hardening
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Mail delivery
MAIL_PROVIDER=brevo
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=SDD Flow
BREVO_API_KEY=
