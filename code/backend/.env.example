# Backend runtime configuration (non-secret template)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/sddflow
JWT_SECRET=change-me-in-production

# Compatibility mapping: if FRONTEND_URL is empty and APP_DOMAIN is set,
# the app can derive FRONTEND_URL from APP_DOMAIN.
APP_DOMAIN=
FRONTEND_URL=http://localhost:5173

# OAuth
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Cookie hardening
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
